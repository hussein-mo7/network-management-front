# Proxied to backend via vite (see vite.config.ts) — must include /v1
VITE_API_BASE_URL=/api/v1

# true = dev login without API; false = real auth against backend (superadmin / admin123)
VITE_SKIP_AUTH_CHECK=false

# Admin users page: true = live API (default with real auth), false = mock-only UI
# VITE_USE_ADMIN_USERS_API=true

# WhatsApp support group (change group without code edits)
# Invite link — used on mobile to open the group in the WhatsApp app
VITE_WHATSAPP_GROUP_INVITE_URL=https://chat.whatsapp.com/FRefWGNhug65BEnFHFV9XV
# Display name — shown in hints on desktop (pick this group in WhatsApp Web)
# Exact group name as shown in WhatsApp (used in message header + button label)
VITE_WHATSAPP_GROUP_NAME=droub b
